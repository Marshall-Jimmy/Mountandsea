{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Creature Data",
  "type": "object",
  "required": [
    "version",
    "creatures"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "creatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
